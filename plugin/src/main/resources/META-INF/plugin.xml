<!-- Plugin configuration. <version> and <idea-version> are patched in by Gradle. -->
<idea-plugin>
    <id>dev.ergo.intellij</id>
    <name>Ergo</name>
    <vendor>Ergo</vendor>

    <description><![CDATA[
        <p><b>Ergo</b> statically determines the concrete error types and values
        a Go function can return, and surfaces them in the Quick Documentation
        popup.</p>
    ]]></description>

    <!-- modules.platform: core APIs. plugins.go: Go PSI, and it restricts the
         plugin to IDEs with the Go plugin (GoLand, or IDEA Ultimate + Go). -->
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.go</depends>

    <extensions defaultExtensionNs="com.intellij.platform.backend.documentation">
        <!-- Supplies an async DocumentationTarget for Go functions/methods: the
             Go plugin's documentation with an appended "Errors (ergo)" section.
             Async because the analyzer runs a subprocess, which is forbidden
             under the read action that wraps synchronous documentation. -->
        <psiTargetProvider implementation="dev.ergo.ErgoDocumentationTargetProvider"/>
        <!-- Navigates the editor when an error link in the section is clicked. -->
        <linkHandler implementation="dev.ergo.ErgoDocLinkHandler"/>
    </extensions>
</idea-plugin>
